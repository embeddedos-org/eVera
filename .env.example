# ============================================================
# Voca — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- LLM Providers (at least one required) ---

# OpenAI (recommended for best experience)
VOCA_LLM_OPENAI_API_KEY=
VOCA_LLM_OPENAI_MODEL=gpt-4o-mini

# Google Gemini (free tier available)
VOCA_LLM_GEMINI_API_KEY=
VOCA_LLM_GEMINI_MODEL=gemini-2.0-flash

# Ollama (free, local — install from https://ollama.ai)
VOCA_LLM_OLLAMA_URL=http://localhost:11434
VOCA_LLM_OLLAMA_MODEL=llama3.2

# Fallback order (comma-separated)
VOCA_LLM_FALLBACK_ORDER=ollama,openai,gemini

# --- Stock Trading (optional) ---

# Alpaca — free at https://alpaca.markets
VOCA_ALPACA_API_KEY=
VOCA_ALPACA_SECRET_KEY=
VOCA_ALPACA_PAPER=true

# Interactive Brokers — requires TWS/Gateway running
VOCA_IBKR_HOST=127.0.0.1
VOCA_IBKR_PORT=7497
VOCA_IBKR_CLIENT_ID=1

# Auto-trade safety limit (USD) — trades above this need confirmation
VOCA_AUTO_TRADE_LIMIT=500

# --- Smart Home (optional) ---

# Home Assistant
VOCA_HA_URL=
VOCA_HA_TOKEN=

# --- Email (optional) ---

VOCA_SMTP_HOST=
VOCA_SMTP_PORT=587
VOCA_SMTP_USER=
VOCA_SMTP_PASS=

# --- Server ---

VOCA_SERVER_HOST=127.0.0.1
VOCA_SERVER_PORT=8000
VOCA_SERVER_CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]

# Security: API key for authenticating all requests (set a strong random key)
VOCA_SERVER_API_KEY=
# Security: Shared secret for TradingView webhook verification
VOCA_SERVER_WEBHOOK_SECRET=

# --- Voice (CLI mode) ---

VOCA_VOICE_STT_MODEL=small
VOCA_VOICE_STT_DEVICE=cpu
VOCA_VOICE_VAD_AGGRESSIVENESS=2

# --- Memory ---

VOCA_MEMORY_WORKING_MEMORY_MAX_TURNS=20
VOCA_MEMORY_EMBEDDING_MODEL=all-MiniLM-L6-v2
