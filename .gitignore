# ============================================================
# eVera — .gitignore
# ============================================================

# --- Secrets & Credentials ---
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
secrets/
credentials/

# --- Data directories ---
data/
/deploy/certbot/conf/
/deploy/certbot/www/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.pyc

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# --- Testing ---
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml
*.cover
*.py,cover
MagicMock/

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Node.js (mobile) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
mobile/.expo/
mobile/android/
mobile/ios/
mobile/build/

# --- Build artifacts ---
build-*/
target/
*.exe
*.dll
*.dylib

# --- Logs ---
*.log
logs/
*.log.*

# --- Docker ---
.dockerignore.local

# --- Misc ---
*.tmp
*.bak
*.swp
.cache/
